rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null && request.auth.token.vet == true;
    }

    function hasCap(cap) {
      return signedIn() && cap in request.auth.token.caps;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isImmutable(field) {
      return resource.data[field] == request.resource.data[field];
    }

    function isServerStamped(field) {
      return request.resource.data[field] == request.time;
    }

    function hasTokenName() {
      return "name" in request.auth.token && request.auth.token.name is string;
    }

    match /users/{uid} {
      allow read: if (request.auth != null && request.auth.uid == uid) || hasCap("usr");
      allow create: if false;
      allow update: if (
          (isSelf(uid) && request.resource.data.diff(resource.data).changedKeys().hasOnly(["displayName", "updatedAt"])
            && request.resource.data.displayName is string
            && request.resource.data.displayName.size() >= 1
            && request.resource.data.displayName.size() <= 80)
          || (hasCap("rsg") && uid != request.auth.uid
            && request.resource.data.diff(resource.data).changedKeys().hasOnly(["roleId", "updatedAt"])
            && request.resource.data.roleId is string
            && request.resource.data.roleId.size() >= 1
            && request.resource.data.roleId.size() <= 60
            && request.resource.data.roleId != "admin")
          || (hasCap("uap") && uid != request.auth.uid
            && request.resource.data.diff(resource.data).changedKeys().hasOnly(["approved", "roleId", "approvedAt", "approvedBy", "updatedAt"])
            && request.resource.data.approved is bool
            && request.resource.data.roleId is string
            && request.resource.data.roleId.size() >= 1
            && request.resource.data.roleId.size() <= 60
            && request.resource.data.roleId != "admin"
            && request.resource.data.approvedBy is string
            && request.resource.data.approvedBy == request.auth.uid
            && request.resource.data.approvedAt == request.time)
        )
        && isImmutable("email")
        && isImmutable("createdAt")
        && isServerStamped("updatedAt");
      allow delete: if false;
    }

    match /roles/{roleId} {
      function valid() {
        let d = request.resource.data;
        return d.keys().hasAll(["name", "capabilities", "locked", "createdAt", "updatedAt", "createdBy", "updatedBy", "schemaVersion"])
          && d.keys().hasOnly(["name", "description", "capabilities", "locked", "createdAt", "updatedAt", "createdBy", "updatedBy", "capsVer", "schemaVersion"])
          && d.name is string && d.name.size() >= 1 && d.name.size() <= 60
          && (!("description" in d.keys()) || (d.description is string && d.description.size() <= 300))
          && d.capabilities is list && d.capabilities.size() <= 64
          && d.locked is bool
          && d.createdBy is string && d.createdBy.size() <= 128
          && d.updatedBy is string && d.updatedBy.size() <= 128
          && (!("capsVer" in d.keys()) || (d.capsVer is int && d.capsVer >= 0))
          && d.schemaVersion == 1
          && !(d.locked == false
              && "roles.manage" in d.capabilities
              && "users.approve" in d.capabilities
              && "allowlist.manage" in d.capabilities);
      }
      allow read: if hasCap("rr");
      allow create: if hasCap("rm")
        && valid()
        && request.resource.data.locked == false
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.updatedBy == request.auth.uid
        && isServerStamped("createdAt")
        && isServerStamped("updatedAt");
      allow update: if hasCap("rm")
        && valid()
        && resource.data.locked == false
        && request.resource.data.locked == false
        && request.resource.data.updatedBy == request.auth.uid
        && isImmutable("createdAt")
        && isImmutable("createdBy")
        && isServerStamped("updatedAt");
      allow delete: if hasCap("rm") && resource.data.locked == false;
    }

    match /allowlist/{emailNorm} {
      function valid() {
        let d = request.resource.data;
        return d.keys().hasAll(["email", "defaultRoleId", "invitedBy", "invitedAt", "schemaVersion"])
          && d.keys().hasOnly(["email", "defaultRoleId", "invitedBy", "invitedAt", "notes", "schemaVersion"])
          && d.email is string && d.email.size() >= 3 && d.email.size() <= 120 && d.email.matches("^[^=+\\-@][^@]*@[^@]+\\.[^@]+$")
          && d.email.lower() == emailNorm
          && d.defaultRoleId is string && d.defaultRoleId.size() >= 1 && d.defaultRoleId.size() <= 60
          && d.defaultRoleId != "admin"
          && d.invitedBy is string && d.invitedBy.size() <= 128
          && (!("notes" in d.keys()) || (d.notes is string && d.notes.size() <= 500))
          && d.schemaVersion == 1;
      }
      allow read: if hasCap("lr");
      allow create: if hasCap("lm")
        && valid()
        && request.resource.data.invitedBy == request.auth.uid
        && isServerStamped("invitedAt");
      allow update: if hasCap("lm")
        && valid()
        && isImmutable("invitedAt")
        && isImmutable("invitedBy");
      allow delete: if hasCap("lm");
    }

    match /accessRequests/{emailNorm} {
      allow read: if hasCap("lm");
      allow create, update, delete: if false;
    }

    match /attivita/{attivitaId} {
      function validCreate() {
        let d = request.resource.data;
        return d.keys().hasAll(["data", "aziendaId", "aziendaNome", "tipoId", "tipoNome", "oraria", "tariffa", "totale", "ownerUid", "ownerEmail", "ownerName", "createdAt", "updatedAt", "isDeleted", "schemaVersion"])
          && d.keys().hasOnly(["data", "aziendaId", "aziendaNome", "tipoId", "tipoNome", "oraria", "tariffa", "ore", "totale", "note", "ownerUid", "ownerEmail", "ownerName", "createdAt", "updatedAt", "isDeleted", "schemaVersion"])
          && d.data is timestamp
          && d.aziendaId is string && d.aziendaId.size() >= 1 && d.aziendaId.size() <= 64
          && d.aziendaNome is string && d.aziendaNome.size() >= 1 && d.aziendaNome.size() <= 200
          && d.tipoId is string && d.tipoId.size() >= 1 && d.tipoId.size() <= 64
          && d.tipoNome is string && d.tipoNome.size() >= 1 && d.tipoNome.size() <= 80
          && d.oraria is bool
          && d.tariffa is number && d.tariffa > 0 && d.tariffa <= 100000
          && d.oraria == ("ore" in d.keys())
          && (!("ore" in d.keys()) || (d.ore is number && d.ore > 0 && d.ore <= 24))
          && d.totale is number && d.totale >= 0 && d.totale <= 2400000
          && (!("note" in d.keys()) || (d.note is string && d.note.size() <= 2000))
          && d.ownerName is string && d.ownerName.size() >= 1 && d.ownerName.size() <= 80
          && !d.ownerName.matches("^[=+\\-@].*")
          && d.isDeleted == false
          && d.schemaVersion == 1;
      }
      function validUpdate() {
        let d = request.resource.data;
        return d.keys().hasAll(["data", "aziendaId", "aziendaNome", "tipoId", "tipoNome", "oraria", "tariffa", "totale", "ownerUid", "ownerEmail", "ownerName", "createdAt", "updatedAt", "isDeleted", "schemaVersion"])
          && d.keys().hasOnly(["data", "aziendaId", "aziendaNome", "tipoId", "tipoNome", "oraria", "tariffa", "ore", "totale", "note", "ownerUid", "ownerEmail", "ownerName", "createdAt", "updatedAt", "isDeleted", "deletedAt", "deletedBy", "updatedBy", "updatedByName", "schemaVersion"])
          && d.data is timestamp
          && d.aziendaId is string && d.aziendaId.size() >= 1 && d.aziendaId.size() <= 64
          && d.aziendaNome is string && d.aziendaNome.size() >= 1 && d.aziendaNome.size() <= 200
          && d.tipoId is string && d.tipoId.size() >= 1 && d.tipoId.size() <= 64
          && d.tipoNome is string && d.tipoNome.size() >= 1 && d.tipoNome.size() <= 80
          && d.oraria is bool
          && d.tariffa is number && d.tariffa > 0 && d.tariffa <= 100000
          && (!("ore" in d.keys()) || (d.ore is number && d.ore > 0 && d.ore <= 24))
          && d.totale is number && d.totale >= 0 && d.totale <= 2400000
          && (!("note" in d.keys()) || (d.note is string && d.note.size() <= 2000))
          && (!("updatedBy" in d.keys()) || (d.updatedBy is string && d.updatedBy.size() <= 128))
          && (!("updatedByName" in d.keys())
              || (d.updatedByName is string && d.updatedByName.size() >= 1 && d.updatedByName.size() <= 80
                  && !d.updatedByName.matches("^[=+\\-@].*")))
          && d.isDeleted is bool
          && d.schemaVersion == 1
          && (d.isDeleted == false
              ? !("deletedAt" in d.keys()) && !("deletedBy" in d.keys())
              : (d.deletedAt is timestamp && d.deletedBy == request.auth.uid));
      }
      allow read: if "isDeleted" in resource.data
        && ((resource.data.isDeleted == false && hasCap("ara"))
            || (resource.data.isDeleted == true
                && ((hasCap("hro") && resource.data.ownerUid == request.auth.uid)
                    || hasCap("hra"))));
      allow create: if hasCap("ac")
        && validCreate()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerEmail == request.auth.token.email
        && hasTokenName()
        && request.resource.data.ownerName == request.auth.token.name
        && isServerStamped("createdAt")
        && isServerStamped("updatedAt");
      allow update: if (
          (
            (hasCap("auo") && resource.data.ownerUid == request.auth.uid
                && resource.data.isDeleted == false)
            || (hasCap("aua") && resource.data.isDeleted == false)
            || (hasCap("ado") && resource.data.ownerUid == request.auth.uid
                && resource.data.isDeleted == false
                && request.resource.data.isDeleted == true
                && request.resource.data.diff(resource.data).changedKeys()
                    .hasOnly(["isDeleted", "deletedAt", "deletedBy", "updatedAt", "updatedBy", "updatedByName"]))
            || (hasCap("ada") && resource.data.isDeleted == false
                && request.resource.data.isDeleted == true
                && request.resource.data.diff(resource.data).changedKeys()
                    .hasOnly(["isDeleted", "deletedAt", "deletedBy", "updatedAt", "updatedBy", "updatedByName"]))
            || (hasCap("hso") && resource.data.ownerUid == request.auth.uid
                && resource.data.isDeleted == true
                && request.resource.data.isDeleted == false
                && request.resource.data.diff(resource.data).changedKeys()
                    .hasOnly(["isDeleted", "deletedAt", "deletedBy", "updatedAt", "updatedBy", "updatedByName"]))
            || (hasCap("hsa") && resource.data.isDeleted == true
                && request.resource.data.isDeleted == false
                && request.resource.data.diff(resource.data).changedKeys()
                    .hasOnly(["isDeleted", "deletedAt", "deletedBy", "updatedAt", "updatedBy", "updatedByName"]))
          )
          && validUpdate()
          && isImmutable("ownerUid")
          && isImmutable("ownerEmail")
          && isImmutable("ownerName")
          && isImmutable("createdAt")
          && isServerStamped("updatedAt")
          && (!("updatedBy" in request.resource.data.keys())
              || request.resource.data.updatedBy == request.auth.uid)
          && (!("updatedByName" in request.resource.data.keys())
              || (hasTokenName() && request.resource.data.updatedByName == request.auth.token.name))
          && (request.resource.data.isDeleted == resource.data.isDeleted
              || (resource.data.isDeleted == false && request.resource.data.isDeleted == true && isServerStamped("deletedAt"))
              || (resource.data.isDeleted == true && request.resource.data.isDeleted == false))
        );
      allow delete: if hasCap("hp") && resource.data.isDeleted == true;
    }

    match /aziende/{aziendaId} {
      function valid() {
        let d = request.resource.data;
        return d.keys().hasAll(["nome", "nomeNorm", "createdAt", "updatedAt", "createdBy", "updatedBy", "createdByName", "updatedByName", "isDeleted", "schemaVersion"])
          && d.keys().hasOnly(["nome", "nomeNorm", "indirizzo", "piva", "emailFatturazione", "cadenzaFatturazione", "tipoAllevamento", "numeroCapi", "telefono", "note", "createdAt", "updatedAt", "createdBy", "updatedBy", "createdByName", "updatedByName", "isDeleted", "deletedAt", "schemaVersion"])
          && d.nome is string && d.nome.size() >= 1 && d.nome.size() <= 200
          && d.nomeNorm is string && d.nomeNorm.size() >= 1 && d.nomeNorm.size() <= 200
          && (!("indirizzo" in d.keys()) || (d.indirizzo is string && d.indirizzo.size() <= 300))
          && (!("piva" in d.keys()) || (d.piva is string && d.piva.matches("^[0-9]{11}$")))
          && (!("emailFatturazione" in d.keys()) || (d.emailFatturazione is string && d.emailFatturazione.size() <= 120 && d.emailFatturazione.matches("^[^=+\\-@][^@]*@[^@]+\\.[^@]+$")))
          && (!("cadenzaFatturazione" in d.keys()) || d.cadenzaFatturazione in ["monthly", "quarterly", "semiannual"])
          && (!("tipoAllevamento" in d.keys()) || d.tipoAllevamento in ["bovini", "ovini", "caprini", "suini", "avicoli", "equini", "misto", "altro"])
          && (!("numeroCapi" in d.keys()) || (d.numeroCapi is int && d.numeroCapi >= 0 && d.numeroCapi <= 100000))
          && (!("telefono" in d.keys()) || (d.telefono is string && d.telefono.size() <= 40))
          && (!("note" in d.keys()) || (d.note is string && d.note.size() <= 1000))
          && d.createdBy is string && d.createdBy.size() <= 128
          && d.updatedBy is string && d.updatedBy.size() <= 128
          && d.createdByName is string && d.createdByName.size() >= 1 && d.createdByName.size() <= 80
          && d.updatedByName is string && d.updatedByName.size() >= 1 && d.updatedByName.size() <= 80
          && d.isDeleted is bool
          && d.schemaVersion == 1;
      }
      allow read: if hasCap("zr");
      allow create: if hasCap("zc")
        && valid()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.isDeleted == false
        && !("deletedAt" in request.resource.data.keys())
        && isServerStamped("createdAt")
        && isServerStamped("updatedAt");
      allow update: if hasCap("zu")
        && valid()
        && request.resource.data.updatedBy == request.auth.uid
        && isImmutable("createdAt")
        && isImmutable("createdBy")
        && isImmutable("createdByName")
        && isServerStamped("updatedAt")
        && (request.resource.data.isDeleted == resource.data.isDeleted
            || (resource.data.isDeleted == false && request.resource.data.isDeleted == true && isServerStamped("deletedAt")));
      allow delete: if false;
    }

    match /activity_types/{typeId} {
      function valid() {
        let d = request.resource.data;
        return d.keys().hasAll(["nome", "ordine", "attivo", "createdAt", "updatedAt", "schemaVersion"])
          && d.keys().hasOnly(["nome", "ordine", "attivo", "tariffaStandard", "createdAt", "updatedAt", "schemaVersion"])
          && d.nome is string && d.nome.size() >= 1 && d.nome.size() <= 80
          && d.ordine is int && d.ordine >= 0 && d.ordine <= 1000
          && d.attivo is bool
          && (!("tariffaStandard" in d.keys()) || (d.tariffaStandard is number && d.tariffaStandard >= 0 && d.tariffaStandard <= 100000))
          && d.schemaVersion == 1;
      }
      allow read: if hasCap("tr");
      allow create: if hasCap("tm")
        && valid()
        && isServerStamped("createdAt")
        && isServerStamped("updatedAt");
      allow update: if hasCap("tm")
        && valid()
        && isImmutable("createdAt")
        && isServerStamped("updatedAt");
      allow delete: if hasCap("tm");
    }

    match /audit/{auditId} {
      allow read: if hasCap("ur");
      allow write: if false;
    }

    match /payments/{paymentId} {
      function valid() {
        let d = request.resource.data;
        return d.keys().hasAll(["aziendaId", "aziendaNome", "periodoFinoA", "createdAt", "updatedAt", "createdBy", "updatedBy", "createdByName", "updatedByName", "schemaVersion"])
          && d.keys().hasOnly(["aziendaId", "aziendaNome", "periodoFinoA", "importoPagato", "metodoPagamento", "note", "createdAt", "updatedAt", "createdBy", "updatedBy", "createdByName", "updatedByName", "schemaVersion"])
          && d.aziendaId is string && d.aziendaId.size() >= 1 && d.aziendaId.size() <= 64
          && d.aziendaNome is string && d.aziendaNome.size() >= 1 && d.aziendaNome.size() <= 200
          && d.periodoFinoA is timestamp
          && (!("importoPagato" in d.keys()) || (d.importoPagato is number && d.importoPagato >= 0 && d.importoPagato <= 1000000))
          && (!("metodoPagamento" in d.keys()) || d.metodoPagamento in ["bonifico", "contanti", "altro"])
          && (!("note" in d.keys()) || (d.note is string && d.note.size() <= 500))
          && d.createdBy is string && d.createdBy.size() <= 128
          && d.updatedBy is string && d.updatedBy.size() <= 128
          && d.createdByName is string && d.createdByName.size() >= 1 && d.createdByName.size() <= 80
          && d.updatedByName is string && d.updatedByName.size() >= 1 && d.updatedByName.size() <= 80
          && d.schemaVersion == 1;
      }
      allow read: if (hasCap("pr") && resource.data.createdBy == request.auth.uid)
        || hasCap("pra");
      allow create: if hasCap("pm")
        && valid()
        && request.resource.data.createdBy == request.auth.uid
        && isServerStamped("createdAt")
        && isServerStamped("updatedAt");
      allow update: if false;
      allow delete: if (hasCap("pm") && resource.data.createdBy == request.auth.uid)
        || hasCap("pma");
    }

    match /reminders/{reminderId} {
      function valid() {
        let d = request.resource.data;
        return d.keys().hasAll(["aziendaId", "aziendaNome", "titolo", "dueAt", "done", "createdAt", "updatedAt", "createdBy", "schemaVersion"])
          && d.keys().hasOnly(["aziendaId", "aziendaNome", "titolo", "dueAt", "note", "done", "doneAt", "createdAt", "updatedAt", "createdBy", "schemaVersion"])
          && d.aziendaId is string && d.aziendaId.size() >= 1 && d.aziendaId.size() <= 64
          && d.aziendaNome is string && d.aziendaNome.size() >= 1 && d.aziendaNome.size() <= 200
          && d.titolo is string && d.titolo.size() >= 1 && d.titolo.size() <= 120
          && d.dueAt is timestamp
          && (!("note" in d.keys()) || (d.note is string && d.note.size() <= 500))
          && d.done is bool
          && (d.done == false
              ? (!("doneAt" in d.keys()) || d.doneAt == null)
              : d.doneAt is timestamp)
          && d.createdBy is string && d.createdBy.size() <= 128
          && d.schemaVersion == 1;
      }
      allow read: if hasCap("mr");
      allow create: if hasCap("mc")
        && valid()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.done == false
        && !("doneAt" in request.resource.data.keys())
        && isServerStamped("createdAt")
        && isServerStamped("updatedAt");
      allow update: if (
          (hasCap("muo") && resource.data.createdBy == request.auth.uid)
          || hasCap("mua")
        )
        && valid()
        && isImmutable("createdAt")
        && isImmutable("createdBy")
        && isImmutable("aziendaId")
        && isServerStamped("updatedAt");
      allow delete: if (hasCap("mdo") && resource.data.createdBy == request.auth.uid)
        || hasCap("mda");
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
