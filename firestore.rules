rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null && request.auth.token.vet == true;
    }

    function hasCap(cap) {
      return signedIn() && cap in request.auth.token.caps;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isImmutable(field) {
      return resource.data[field] == request.resource.data[field];
    }

    function isServerStamped(field) {
      return request.resource.data[field] == request.time;
    }

    match /users/{uid} {
      allow read: if isSelf(uid) || hasCap("users.read.all");
      allow create: if false;
      allow update: if (
        (isSelf(uid) && request.resource.data.diff(resource.data).changedKeys().hasOnly(["displayName", "updatedAt"]))
        || hasCap("roles.assign")
      )
        && isImmutable("email")
        && isImmutable("createdAt")
        && isServerStamped("updatedAt");
      allow delete: if false;
    }

    match /roles/{roleId} {
      allow read: if hasCap("roles.read");
      allow create: if hasCap("roles.manage")
        && request.resource.data.locked == false
        && isServerStamped("createdAt")
        && isServerStamped("updatedAt");
      allow update: if hasCap("roles.manage")
        && resource.data.locked == false
        && request.resource.data.locked == false
        && isImmutable("createdAt")
        && isServerStamped("updatedAt");
      allow delete: if hasCap("roles.manage") && resource.data.locked == false;
    }

    match /allowlist/{emailNorm} {
      allow read: if hasCap("allowlist.read");
      allow create: if hasCap("allowlist.manage")
        && isServerStamped("invitedAt");
      allow update: if hasCap("allowlist.manage")
        && isImmutable("invitedAt");
      allow delete: if hasCap("allowlist.manage");
    }

    match /attivita/{attivitaId} {
      allow get: if (resource.data.isDeleted == false && hasCap("activities.read.all"))
        || (resource.data.isDeleted == true
            && ((hasCap("trash.read.own") && resource.data.ownerUid == request.auth.uid)
                || hasCap("trash.read.any")));
      allow list: if hasCap("activities.read.all")
        || hasCap("trash.read.own")
        || hasCap("trash.read.any");
      allow create: if hasCap("activities.create")
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerEmail == request.auth.token.email
        && request.resource.data.ownerName == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.displayName
        && request.resource.data.isDeleted == false
        && isServerStamped("createdAt")
        && isServerStamped("updatedAt");
      allow update: if (
          (
            (hasCap("activities.update.own") && resource.data.ownerUid == request.auth.uid)
            || hasCap("activities.update.any")
            || (hasCap("activities.delete.own") && resource.data.ownerUid == request.auth.uid
                && request.resource.data.isDeleted == true)
            || (hasCap("activities.delete.any") && request.resource.data.isDeleted == true)
          )
          && isImmutable("ownerUid")
          && isImmutable("ownerEmail")
          && isImmutable("ownerName")
          && isImmutable("createdAt")
          && isServerStamped("updatedAt")
        );
      allow delete: if false;
    }

    match /aziende/{aziendaId} {
      allow read: if hasCap("aziende.read");
      allow create: if hasCap("aziende.create")
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.isDeleted == false
        && isServerStamped("createdAt")
        && isServerStamped("updatedAt");
      allow update: if hasCap("aziende.update")
        && isImmutable("createdAt")
        && isImmutable("createdBy")
        && isImmutable("createdByName")
        && isServerStamped("updatedAt");
      allow delete: if false;
    }

    match /activity_types/{typeId} {
      allow read: if hasCap("activity_types.read");
      allow create: if hasCap("activity_types.manage")
        && isServerStamped("createdAt")
        && isServerStamped("updatedAt");
      allow update: if hasCap("activity_types.manage")
        && isImmutable("createdAt")
        && isServerStamped("updatedAt");
      allow delete: if hasCap("activity_types.manage");
    }

    match /audit/{auditId} {
      allow read: if hasCap("audit.read");
      allow write: if false;
    }

    match /payments/{paymentId} {
      allow read: if hasCap("payments.read");
      allow create: if hasCap("payments.manage")
        && request.resource.data.createdBy == request.auth.uid
        && isServerStamped("createdAt")
        && isServerStamped("updatedAt");
      allow update: if false;
      allow delete: if hasCap("payments.manage");
    }

    match /reminders/{reminderId} {
      allow read: if hasCap("reminders.read");
      allow create: if hasCap("reminders.create")
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.done == false
        && isServerStamped("createdAt")
        && isServerStamped("updatedAt");
      allow update: if (
          (hasCap("reminders.update.own") && resource.data.createdBy == request.auth.uid)
          || hasCap("reminders.update.any")
        )
        && isImmutable("createdAt")
        && isImmutable("createdBy")
        && isServerStamped("updatedAt");
      allow delete: if (hasCap("reminders.delete.own") && resource.data.createdBy == request.auth.uid)
        || hasCap("reminders.delete.any");
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
